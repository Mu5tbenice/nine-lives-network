# ===========================================
# Nine Lives Network - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ----- Supabase -----
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# ----- Twitter API (Main App) -----
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ----- @9LVNetwork Account -----
NINELIVES_ACCESS_TOKEN=your_9lvnetwork_access_token
NINELIVES_ACCESS_SECRET=your_9lvnetwork_access_secret

# ----- @9LV_Nerm Bot Account -----
NERM_ACCESS_TOKEN=your_nerm_access_token
NERM_ACCESS_SECRET=your_nerm_access_secret

# ----- Server -----
PORT=3000
NODE_ENV=development

# ----- Session Secret -----
SESSION_SECRET=generate_a_random_string_here

# ----- Supabase MCP -----
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token_here
